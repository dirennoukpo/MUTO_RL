# Profil par defaut pour un nouvel utilisateur
# Ce fichier est charge si USER_NAME n'est ni "pi" ni "jetson".
# Vous pouvez l'ajuster a votre machine.

# Identite
CONTAINER_NAME=muto_dev
ROBOT_ROLE=DRIVER

# Reseau
TARGET_IP=10.0.0.1
DOMAIN_ID=33
LOCALHOST_ONLY=0

# Interface et chemins
MY_DISPLAY=:0
USER_HOME=/home/muto_rl
WORKING_DIR=/home/muto_rl/TEKBOT_ROBOTICS
