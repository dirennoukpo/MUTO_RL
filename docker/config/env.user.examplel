# ── Tailscale Auth Key ─────────────────────────────────────────
# Générez une clé sur : https://login.tailscale.com/admin/settings/keys
# Recommandé : clé "reusable" + tag "tag:container" pour désactiver l'expiration
## Tailscale VPN
TS_AUTHKEY=
TS_HOSTNAME=MUTO-RL
TS_ACCEPT_ROUTES=false
TS_ADVERTISE_EXIT_NODE=false